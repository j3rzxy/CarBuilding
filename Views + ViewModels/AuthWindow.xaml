<Window x:Class="CarBuilding.View.AuthWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CarBuilding.View"
             mc:Ignorable="d" 
             Height="450" Width="300"
             WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl Margin="10" Background="White" BorderBrush="#DDDDDD">

            <TabItem Header="ВХОД" FontSize="14">
                <StackPanel Margin="30" VerticalAlignment="Center">

                    <TextBlock Text="Логин" Foreground="#555555" Margin="0,0,0,5" />
                    <TextBox x:Name="LoginBox"
                             KeyDown="LoginBox_KeyDown"
                             Height="30" Padding="5" Margin="0,0,0,15" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Пароль" Foreground="#555555" Margin="0,0,0,5" />
                    <PasswordBox x:Name="LoginPasswordBox"
                                 KeyDown="LoginPasswordBox_KeyDown"
                                 Height="30" Padding="5" Margin="0,0,0,30" 
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <Button Content="ВОЙТИ"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=LoginPasswordBox}"
                            Height="35" 
                            Background="#0078D7" 
                            Foreground="White" 
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold" Click="Login"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="РЕГИСТРАЦИЯ" FontSize="14">
                <StackPanel Margin="30" VerticalAlignment="Center">

                    <TextBlock Text="Придумайте логин" Foreground="#555555" Margin="0,0,0,5" />
                    <TextBox x:Name="RegLoginBox"
                             KeyDown="RegLoginBox_KeyDown"
                             Height="30" Padding="5" Margin="0,0,0,15" 
                             BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Пароль" Foreground="#555555" Margin="0,0,0,5" />
                    <PasswordBox x:Name="RegPasswordBox"
                                 KeyDown="RegPasswordBox_KeyDown"
                                 Height="30" Padding="5" Margin="0,0,0,15" 
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <TextBlock Text="Повторите пароль" Foreground="#555555" Margin="0,0,0,5" />
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 KeyDown="ConfirmPasswordBox_KeyDown"
                                 Height="30" Padding="5" Margin="0,0,0,30" 
                                 BorderBrush="#CCCCCC" BorderThickness="1"/>

                    <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ"
                            Height="35" 
                            Background="#107C41" 
                            Foreground="White" 
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold" Click="Register"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>